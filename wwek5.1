% Read the image
img = imread('breast_cancer_img1(4).bmp');

% Show original image
figure;
imshow(img);
title('Original Mammography Image');

% Select region manually
disp('Click top-left corner of the mass');
[x1, y1] = ginput(1);

disp('Click bottom-right corner of the mass');
[x2, y2] = ginput(1);

% Crop the selected region
cropped_mass = img(round(y1):round(y2), round(x1):round(x2), :);

% Save cropped image
imwrite(cropped_mass, 'mass.bmp');
disp('Mass saved as mass.bmp');

% Display cropped image
figure;
imshow(cropped_mass);
title('Cropped Mass Image');